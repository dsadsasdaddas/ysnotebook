{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "baseUrl": ".",
    "paths": {
      "@ys/ui/*": ["packages/ui/src/*"],
      "@ys/shared/*": ["packages/shared/src/*"],
      "@ys/editor-core/*": ["packages/editor-core/src/*"]
    }
  }
}
